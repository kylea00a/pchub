<Window x:Class="PCHUB.Renter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:rendering="clr-namespace:PCHUB.Renter.Rendering"
        Title="PCHUB Renter" Height="720" Width="900"
        Background="#121216" Foreground="#E8E8EE">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*" MinHeight="280"/>
      <RowDefinition Height="140"/>
    </Grid.RowDefinitions>

    <TextBlock Text="PCHUB Renter" FontSize="22" FontWeight="SemiBold" Foreground="#78C8FF"/>

    <StackPanel Grid.Row="1" Margin="0,12,0,0">
      <TextBlock Text="API URL" FontSize="11" Opacity="0.7"/>
      <TextBox x:Name="ApiUrlBox" Text="https://api.pchub.cloud" Margin="0,4,0,8" Padding="8"/>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,8,0">
          <TextBlock Text="Email" FontSize="11" Opacity="0.7"/>
          <TextBox x:Name="EmailBox" Margin="0,4,0,0" Padding="8"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,8,0">
          <TextBlock Text="Password" FontSize="11" Opacity="0.7"/>
          <PasswordBox x:Name="PasswordBox" Margin="0,4,0,0" Padding="8"/>
        </StackPanel>
        <Button x:Name="LoginBtn" Grid.Column="2" Content="Log in" Click="LoginBtn_Click"
                Padding="12,8" VerticalAlignment="Bottom"/>
      </Grid>
    </StackPanel>

    <StackPanel Grid.Row="2" Margin="0,12,0,0">
      <TextBlock x:Name="SessionLabel" Text="No active rental" TextWrapping="Wrap" Margin="0,0,0,8"/>
      <Button x:Name="ConnectBtn" Content="Connect" Click="ConnectBtn_Click" IsEnabled="False" Padding="10" HorizontalAlignment="Left"/>
      <TextBlock Text="Streaming starts only when you click Connect." FontSize="11" Opacity="0.6" Margin="0,6,0,0"/>
    </StackPanel>

    <Border Grid.Row="3" x:Name="VideoBorder" Margin="0,12,0,0" Background="#0A0A0E"
            BorderBrush="#333" BorderThickness="1" Focusable="True" SizeChanged="VideoBorder_SizeChanged">
      <Grid>
        <rendering:GpuVideoHost x:Name="VideoGpuHost" Visibility="Collapsed"/>
        <Image x:Name="VideoImage" Stretch="Uniform" Visibility="Collapsed"/>
        <TextBlock x:Name="VideoPlaceholder" Text="Video appears here after Connect — click to control"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.45" IsHitTestVisible="False"/>
      </Grid>
    </Border>

    <TextBox Grid.Row="4" x:Name="LogBox" Margin="0,12,0,0"
             IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
             Background="#0E0E12" BorderBrush="#333" FontFamily="Consolas" FontSize="11"/>
  </Grid>
</Window>
