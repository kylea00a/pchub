<Window x:Class="PCHUB.Renter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PCHUB Renter" Height="560" Width="520"
        Background="#121216" Foreground="#E8E8EE">
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <TextBlock Text="PCHUB Renter" FontSize="22" FontWeight="SemiBold" Foreground="#78C8FF"/>

    <StackPanel Grid.Row="1" Margin="0,16,0,0">
      <TextBlock Text="API URL" FontSize="11" Opacity="0.7"/>
      <TextBox x:Name="ApiUrlBox" Text="https://api.pchub.cloud" Margin="0,4,0,8" Padding="8"/>
      <TextBlock Text="Email" FontSize="11" Opacity="0.7"/>
      <TextBox x:Name="EmailBox" Margin="0,4,0,8" Padding="8"/>
      <TextBlock Text="Password" FontSize="11" Opacity="0.7"/>
      <PasswordBox x:Name="PasswordBox" Margin="0,4,0,8" Padding="8"/>
      <Button x:Name="LoginBtn" Content="Log in" Click="LoginBtn_Click" Padding="10" Margin="0,4,0,0"/>
    </StackPanel>

    <StackPanel Grid.Row="2" Margin="0,16,0,0">
      <TextBlock x:Name="SessionLabel" Text="No active rental" TextWrapping="Wrap" Margin="0,0,0,8"/>
      <Button x:Name="ConnectBtn" Content="Connect" Click="ConnectBtn_Click" IsEnabled="False" Padding="10"/>
      <TextBlock Text="Streaming starts only when you click Connect." FontSize="11" Opacity="0.6" Margin="0,8,0,0"/>
    </StackPanel>

    <TextBox Grid.Row="3" x:Name="LogBox" Margin="0,16,0,0"
             IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
             Background="#0E0E12" BorderBrush="#333" FontFamily="Consolas" FontSize="11"/>
  </Grid>
</Window>
